<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="laporan_performa" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    
    <parameter name="CompanyName" class="java.lang.String"/>
    <parameter name="Period" class="java.lang.String"/>
    <parameter name="DateGenerated" class="java.lang.String"/>
    
    <queryString>
        <![CDATA[
        SELECT c.judul_content, p.views, p.likes, p.komentar, (p.likes + p.komentar) as engagement
        FROM performa p
        JOIN content c ON p.id_content = c.id_content
        ORDER BY p.id_performa ASC
        ]]>
    </queryString>
    
    <field name="judul_content" class="java.lang.String"/>
    <field name="views" class="java.lang.Integer"/>
    <field name="likes" class="java.lang.Integer"/>
    <field name="komentar" class="java.lang.Integer"/>
    <field name="engagement" class="java.lang.Integer"/>
    
    <title>
        <band height="90">
            <!-- Company Name -->
            <textField>
                <reportElement x="0" y="0" width="280" height="30"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="22" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{CompanyName}]]></textFieldExpression>
            </textField>
            
            <!-- Report Title -->
            <staticText>
                <reportElement x="280" y="0" width="275" height="30"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[LAPORAN PERFORMA KONTEN]]></text>
            </staticText>
            
            <!-- Subtitle info -->
            <staticText>
                <reportElement x="0" y="30" width="555" height="15"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isItalic="true"/>
                </textElement>
                <text><![CDATA[Sistem Manajemen Konten Kreator & Publikasi Platform]]></text>
            </staticText>
            
            <!-- Period -->
            <textField>
                <reportElement x="0" y="50" width="280" height="15"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Periode: " + $P{Period}]]></textFieldExpression>
            </textField>
            
            <!-- Date Generated -->
            <textField>
                <reportElement x="280" y="50" width="275" height="15"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Tanggal Unduh: " + $P{DateGenerated}]]></textFieldExpression>
            </textField>
            
            <!-- Line Separator -->
            <line>
                <reportElement x="0" y="75" width="555" height="1"/>
                <graphicElement>
                    <pen lineWidth="1.5" lineStyle="Solid"/>
                </graphicElement>
            </line>
        </band>
    </title>
    
    <columnHeader>
        <band height="25">
            <staticText>
                <reportElement mode="Opaque" x="0" y="0" width="195" height="25" backcolor="#F5F5F7"/>
                <box leftPadding="5">
                    <pen lineWidth="0.5" lineColor="#E5E5E7"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" isBold="true"/>
                </textElement>
                <text><![CDATA[Judul Konten]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="195" y="0" width="90" height="25" backcolor="#F5F5F7"/>
                <box leftPadding="5">
                    <pen lineWidth="0.5" lineColor="#E5E5E7"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" isBold="true"/>
                </textElement>
                <text><![CDATA[Views]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="285" y="0" width="90" height="25" backcolor="#F5F5F7"/>
                <box leftPadding="5">
                    <pen lineWidth="0.5" lineColor="#E5E5E7"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" isBold="true"/>
                </textElement>
                <text><![CDATA[Likes]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="375" y="0" width="90" height="25" backcolor="#F5F5F7"/>
                <box leftPadding="5">
                    <pen lineWidth="0.5" lineColor="#E5E5E7"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" isBold="true"/>
                </textElement>
                <text><![CDATA[Komentar]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="465" y="0" width="90" height="25" backcolor="#F5F5F7"/>
                <box leftPadding="5">
                    <pen lineWidth="0.5" lineColor="#E5E5E7"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" isBold="true"/>
                </textElement>
                <text><![CDATA[Engagement]]></text>
            </staticText>
        </band>
    </columnHeader>
    
    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="195" height="20"/>
                <box leftPadding="5">
                    <pen lineWidth="0.5" lineColor="#E5E5E7"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{judul_content} != null ? $F{judul_content} : "-"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="195" y="0" width="90" height="20"/>
                <box leftPadding="5">
                    <pen lineWidth="0.5" lineColor="#E5E5E7"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{views} != null ? $F{views} : 0]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="285" y="0" width="90" height="20"/>
                <box leftPadding="5">
                    <pen lineWidth="0.5" lineColor="#E5E5E7"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{likes} != null ? $F{likes} : 0]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="375" y="0" width="90" height="20"/>
                <box leftPadding="5">
                    <pen lineWidth="0.5" lineColor="#E5E5E7"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{komentar} != null ? $F{komentar} : 0]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="465" y="0" width="90" height="20"/>
                <box leftPadding="5">
                    <pen lineWidth="0.5" lineColor="#E5E5E7"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{engagement} != null ? $F{engagement} : 0]]></textFieldExpression>
            </textField>
        </band>
    </detail>
    
    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="555" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Halaman " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
</jasperReport>
